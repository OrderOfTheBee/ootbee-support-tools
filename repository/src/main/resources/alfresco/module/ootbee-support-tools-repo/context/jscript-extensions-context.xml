    <!-- Favorites Service Script Extension -->
    <bean id="ootbee.scriptFavoritesService" parent="baseJavaScriptExtension"
          class="org.orderofthebee.addons.support.tools.repo.jscript.favorites.ScriptFavoritesService">
        <property name="favouritesService" ref="FavouritesService"/>
        <property name="extensionName" value="favorites"/>
        <property name="serviceRegistry" ref="ServiceRegistry"/>
    </bean>

    <!-- Download Service Script Extension -->
    <bean id="ootbee.scriptDownloadService" parent="baseJavaScriptExtension"
          class="org.orderofthebee.addons.support.tools.repo.jscript.download.ScriptDownloadService">
        <property name="extensionName" value="downloads"/>
        <property name="downloadService" ref="DownloadService"/>
        <property name="serviceRegistry" ref="ServiceRegistry"/>
    </bean>

    <!-- Dictionary Service Script Extension -->
    <bean id="ootbee.scriptDictionaryService" parent="baseJavaScriptExtension"
          class="org.orderofthebee.addons.support.tools.repo.jscript.dictionary.ScriptDictionaryService">
        <property name="dictionaryService" ref="DictionaryService"/>
        <property name="extensionName" value="dictionary"/>
        <property name="namespaceService" ref="NamespaceService"/>
    </bean>

    <!-- Hidden Aspect Script Extension -->
    <bean id="ootbee.scriptHiddenAspect" parent="baseJavaScriptExtension"
          class="org.orderofthebee.addons.support.tools.repo.jscript.hidden.ScriptHiddenAspect">
        <property name="extensionName" value="hidden"/>
        <property name="hiddenAspect" ref="hiddenAspect"/>
    </bean>

    <!-- Global Properties Script Extension -->
    <bean id="ootbee.scriptVariablesService" parent="baseJavaScriptExtension"
          class="org.orderofthebee.addons.support.tools.repo.jscript.variables.ScriptVariablesService">
        <property name="properties" ref="global-properties" />
        <property name="extensionName" value="globalProperties" />
    </bean>

    <!-- Permission Service Script Extension -->
    <bean id="ootbee.scriptPermissionService" parent="baseJavaScriptExtension"
          class="org.orderofthebee.addons.support.tools.repo.jscript.permission.ScriptPermissionService">
        <property name="extensionName" value="permissions"/>
        <property name="permissionService" ref="PermissionService"/>
    </bean>

    <!-- Database Service Script Extension (Admin only) -->
    <bean id="ootbee.scriptDatabaseService" parent="baseJavaScriptExtension"
          class="org.orderofthebee.addons.support.tools.repo.jscript.db.ScriptDatabaseService">
        <property name="extensionName" value="database"/>
    </bean>

    <!-- Model Service Script Extension -->
    <bean id="ootbee.scriptModelService" parent="baseJavaScriptExtension"
          class="org.orderofthebee.addons.support.tools.repo.jscript.model.ScriptModelService">
        <property name="extensionName" value="customModel"/>
        <property name="customModelService" ref="customModelService"/>
        <property name="serviceRegistry" ref="ServiceRegistry"/>
    </bean>

    <!-- Messages/I18N Script Extension -->
    <bean id="ootbee.scriptMessagesService" parent="baseJavaScriptExtension"
          class="org.orderofthebee.addons.support.tools.repo.jscript.messages.ScriptMessageService">
        <property name="extensionName" value="messages"/>
        <property name="messageService" ref="messageService"/>
    </bean>

    <!-- Content URL Resolver Script Extension -->
    <bean id="ootbee.scriptContentUrlResolver" parent="baseJavaScriptExtension"
          class="org.orderofthebee.addons.support.tools.repo.jscript.content.ScriptContentUrlResolver">
        <property name="extensionName" value="contentUrls"/>
        <property name="fileFolderService" ref="FileFolderService"/>
    </bean>

    <!-- Ticket Script Extension -->
    <bean id="ootbee.ticketScriptExtension" parent="baseJavaScriptExtension"
          class="org.orderofthebee.addons.support.tools.repo.jscript.ticket.TicketScriptExtension">
        <property name="extensionName" value="ticket"/>
        <property name="serviceRegistry" ref="ServiceRegistry"/>
        <property name="ticketComponent" ref="ticketComponent"/>
    </bean>

    <!-- Attributes Service Script Extension -->
    <bean id="ootbee.scriptAttributesService" parent="baseJavaScriptExtension"
          class="org.orderofthebee.addons.support.tools.repo.jscript.attributes.ScriptAttributeService">
        <property name="extensionName" value="attributes"/>
        <property name="attributeService" ref="AttributeService"/>
    </bean>

    <!-- Job Service Script Extension (Quartz 2.x compatible) -->
    <bean id="ootbee.scriptJobService" parent="baseJavaScriptExtension"
          class="org.orderofthebee.addons.support.tools.repo.jscript.jobs.ScriptJobService">
        <property name="extensionName" value="jobs"/>
        <property name="scheduler" ref="schedulerFactory"/>
        <property name="scriptService" ref="ScriptService"/>
        <property name="jobLockService" ref="JobLockService"/>
    </bean>

    <!-- Cron Expressions Script Extension -->
    <bean id="ootbee.scriptCronExpressions" parent="baseJavaScriptExtension"
          class="org.orderofthebee.addons.support.tools.repo.jscript.jobs.CronExpressions">
        <property name="extensionName" value="cronExpressions"/>
    </bean>

</beans>
