<!DOCTYPE beans PUBLIC '-//SPRING//DTD BEAN//EN' 'http://www.springframework.org/dtd/spring-beans.dtd'>

<beans>
    <!-- Authentication Script Extension -->
    <bean id="ootbee.scriptAuthentication" parent="baseJavaScriptExtension"
          class="org.orderofthebee.addons.support.tools.repo.jscript.authentication.ScriptAuthentication">
        <property name="extensionName" value="auth" />
    </bean>

    <!-- Policy/Behaviour Script Extension -->
    <bean id="ootbee.scriptPolicies" parent="baseJavaScriptExtension"
          class="org.orderofthebee.addons.support.tools.repo.jscript.policy.ScriptPolicies">
        <property name="extensionName" value="policies" />
        <property name="namespaceService" ref="namespaceService" />
        <property name="behaviourFilter" ref="policyBehaviourFilter" />
    </bean>

    <!-- Transaction Script Extension -->
    <bean id="ootbee.scriptTransactions" parent="baseJavaScriptExtension"
          class="org.orderofthebee.addons.support.tools.repo.jscript.transaction.ScriptTransactions">
        <property name="extensionName" value="transactions" />
        <property name="transactionService" ref="TransactionService" />
    </bean>

    <!-- Audit Script Extension -->
    <bean id="ootbee.scriptAuditService" parent="baseJavaScriptExtension"
          class="org.orderofthebee.addons.support.tools.repo.jscript.audit.ScriptAuditService">
        <property name="extensionName" value="audit" />
        <property name="auditService" ref="AuditService" />
    </bean>

    <!-- Repository Script Extension -->
    <bean id="ootbee.scriptRepository" parent="baseJavaScriptExtension"
          class="org.orderofthebee.addons.support.tools.repo.jscript.repository.ScriptRepository">
        <property name="extensionName" value="repository" />
        <property name="repository" ref="repositoryHelper"/>
        <property name="serviceRegistry" ref="ServiceRegistry"/>
        <property name="siteService" ref="SiteService"/>
        <property name="docLibNodeLocator" ref="docLibNodeLocator"/>
        <property name="personService" ref="PersonService"/>
    </bean>

    <!-- Batch Executer Script Extension -->
    <bean id="ootbee.batchExecuterScript" parent="baseJavaScriptExtension"
          class="org.orderofthebee.addons.support.tools.repo.jscript.batchexecuter.ScriptBatchExecuter">
        <property name="extensionName" value="batchExecuter"/>
        <property name="serviceRegistry" ref="ServiceRegistry"/>
        <property name="transactionService" ref="TransactionService" />
        <property name="ruleService" ref="RuleService" />
    </bean>

    <!-- Repo Admin Console Script Extension -->
    <bean id="ootbee.scriptRepoAdminConsole" parent="baseJavaScriptExtension"
          class="org.orderofthebee.addons.support.tools.repo.jscript.repoadmin.ScriptRepoAdminConsole">
        <property name="extensionName" value="repoAdmin" />
        <property name="repoAdminInterpreter" ref="repoAdminInterpreter" />
    </bean>

    <!-- Tenant Admin Console Script Extension -->
    <bean id="ootbee.scriptTenantAdminConsole" parent="baseJavaScriptExtension"
          class="org.orderofthebee.addons.support.tools.repo.jscript.tenant.ScriptTenantAdminConsole">
        <property name="extensionName" value="tenantAdmin" />
        <property name="tenantInterpreter" ref="tenantInterpreter" />
    </bean>

    <!-- Workflow Console Script Extension -->
    <bean id="ootbee.scriptWorkflowConsole" parent="baseJavaScriptExtension"
          class="org.orderofthebee.addons.support.tools.repo.jscript.workflow.ScriptWorkflowConsole">
        <property name="extensionName" value="workflowAdmin" />
        <property name="workflowInterpreter" ref="workflowInterpreter" />
    </bean>

    <!-- Rules Service Script Extension -->
    <bean id="ootbee.scriptRulesService" parent="baseJavaScriptExtension"
          class="org.orderofthebee.addons.support.tools.repo.jscript.rules.ScriptRulesService">
        <property name="ruleService" ref="RuleService"/>
        <property name="extensionName" value="rules"/>
    </bean>

    <!-- Quickshare Service Script Extension -->
    <bean id="ootbee.scriptQuickshareService" parent="baseJavaScriptExtension"
          class="org.orderofthebee.addons.support.tools.repo.jscript.quickshare.ScriptQuickshareService">
        <property name="quickShareService" ref="quickShareService"/>
        <property name="extensionName" value="quickshares"/>
    </bean>

    <!-- Link Service Script Extension -->
    <bean id="ootbee.scriptLinkService" parent="baseJavaScriptExtension"
          class="org.orderofthebee.addons.support.tools.repo.jscript.links.ScriptLinkService">
        <property name="documentLinkService" ref="DocumentLinkService"/>
        <property name="extensionName" value="links"/>
        <property name="serviceRegistry" ref="ServiceRegistry"/>
